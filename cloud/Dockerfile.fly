FROM golang:1.24-alpine AS builder
WORKDIR /src

# Copy protocol + cloud modules (context is repo root)
COPY protocol/ protocol/
COPY cloud/ cloud/

WORKDIR /src/cloud
ENV GOTOOLCHAIN=auto
RUN go mod download
RUN CGO_ENABLED=0 GOOS=linux go build -ldflags="-s -w" -o /cloud ./cmd/cloud/ && chmod +x /cloud

FROM gcr.io/distroless/static-debian12:nonroot
COPY --from=builder --chmod=755 /cloud /cloud
EXPOSE 8080
ENTRYPOINT ["/cloud"]

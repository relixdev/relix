FROM golang:1.24-alpine AS builder
WORKDIR /src

# Copy protocol + relay modules (context is repo root)
COPY protocol/ protocol/
COPY relay/ relay/

WORKDIR /src/relay
ENV GOTOOLCHAIN=auto
RUN go mod download
RUN CGO_ENABLED=0 GOOS=linux go build -ldflags="-s -w" -o /relay ./cmd/relay/ && chmod +x /relay

FROM gcr.io/distroless/static-debian12:nonroot
COPY --from=builder --chmod=755 /relay /relay
EXPOSE 8080
ENTRYPOINT ["/relay"]
